<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="24.0" style="-fx-background-color: #F9FAFB;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edook.frontend.controllers.ReservasController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #F9FAFB; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #1E1E1E; -fx-border-image-width: 1px;" HBox.hgrow="ALWAYS">
            <opaqueInsets>
                <Insets />
            </opaqueInsets>
            <HBox.margin>
                <Insets />
            </HBox.margin>
            <children>
                <HBox alignment="TOP_CENTER" spacing="24.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="56.0" prefWidth="552.0" spacing="42.0" styleClass="campo-busca">
                            <children>
                                <ImageView fitHeight="36.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@Images/Icone%20Lupa.png" />
                                    </image>
                                </ImageView>
                                <TextField prefHeight="41.0" prefWidth="438.0" promptText="Busca" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-border-color: transparent;" styleClass="h3">
                                    <HBox.margin>
                                        <Insets />
                                    </HBox.margin>
                                </TextField>
                            </children>
                            <padding>
                                <Insets bottom="7.0" left="18.0" right="18.0" top="7.0" />
                            </padding>
                            <HBox.margin>
                                <Insets />
                            </HBox.margin>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="56.0" prefWidth="72.0" styleClass="campo-busca">
                            <children>
                                <ImageView fitHeight="36.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@Images/Icone%20Filtro.png" />
                                    </image>
                                </ImageView>
                            </children>
                            <padding>
                                <Insets bottom="7.0" left="18.0" right="18.0" top="7.0" />
                            </padding>
                        </HBox>
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                </HBox>
                <TableView fx:id="tabelaReservas" styleClass="tabela" VBox.vgrow="ALWAYS">
                    <columns>
                  <TableColumn fx:id="colFuncionario" prefWidth="75.0" text="Funcionário" />
                  <TableColumn fx:id="colTitulo" prefWidth="75.0" text="Título" />
                        <TableColumn fx:id="colData" prefWidth="75.0" text="Data" />
                        <TableColumn fx:id="colHorario" prefWidth="75.0" text="Horário" />
                        <TableColumn fx:id="colEquipamento" prefWidth="75.0" text="Equipamento" />
                        <TableColumn fx:id="colLocal" prefWidth="75.0" text="Local" />
                        <TableColumn fx:id="colStatus" prefWidth="75.0" text="Status" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="24.0">
                    <children>
                        <Button fx:id="btnAdicionarReserva" mnemonicParsing="false" styleClass="botao" text="  Adicionar Reserva" textFill="#f9fafb">
                            <graphic>
                                <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@Images/Icone%20Nova%20Reserva.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="btnCancelarReserva" mnemonicParsing="false" styleClass="botao" text="  Cancelar Reserva" textFill="#f9fafb">
                            <graphic>
                                <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@Images/Icone%20Cancelar%20Reserva.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                  <Button fx:id="btnCancelarReserva1" layoutX="353.0" layoutY="35.0" mnemonicParsing="false" styleClass="botao" text="  Minhas Reservas" textFill="#f9fafb">
                     <graphic>
                        <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@Images/Icone%20Minhas%20Reservas.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="24.0" left="96.0" right="96.0" top="24.0" />
            </padding>
        </VBox>
    </children>
</HBox>
