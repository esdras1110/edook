<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox alignment="CENTER" spacing="24.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label fx:id="lblHorario" styleClass="h3" text="Label" textFill="#111827">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <HBox HBox.hgrow="ALWAYS">
         <children>
            <VBox alignment="CENTER" spacing="12.0" style="-fx-border-color: #1A56DB; -fx-border-width: 0 0 0 4;" HBox.hgrow="ALWAYS">
               <children>
                  <Label fx:id="lblLocal" styleClass="txt" text="Label" />
                  <Label fx:id="lblTitulo" styleClass="txt" text="Label" />
               </children>
               <padding>
                  <Insets left="6.0" />
               </padding>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="12.0" left="6.0" right="6.0" top="12.0" />
   </padding>
</HBox>
