<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-background-color: white;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edook.frontend.controllers.ExclusaoUsuarioController">
    <children>
        <Label styleClass="h2-Inter" text="Exclusão de Usuário" textFill="#1a56db" />
      <Label fx:id="lblErro1" styleClass="txt" text="Digite o CPF do usuário que deseja excluir:" />
        <VBox spacing="6.0">
            <children>
                <Label styleClass="h3" text="CPF" />
                <TextField fx:id="txtCPF" prefHeight="56.0" prefWidth="360.0" style="-fx-border-color: #6B7280; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-width: 1px;" styleClass="subtitulo" />
            </children>
        </VBox>
        <Label fx:id="lblErro" styleClass="txt" />
        <HBox alignment="CENTER" spacing="24.0">
            <children>
                <Button mnemonicParsing="false" onAction="#onClickCancelar" styleClass="botao-var" text="Cancelar" />
                <Button mnemonicParsing="false" onAction="#onClickEnviar" styleClass="botao" text="Enviar" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
</VBox>
